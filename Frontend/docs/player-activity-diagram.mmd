%%{init: {
  "theme": "base",
  "themeVariables": {
    "background": "#ffffff",
    "fontFamily": "Arial",
    "fontSize": "26px",
    "primaryColor": "#eef2ff",
    "primaryBorderColor": "#4f46e5",
    "primaryTextColor": "#111827",
    "lineColor": "#374151"
  },
  "flowchart": {
    "nodeSpacing": 70,
    "rankSpacing": 95,
    "curve": "linear",
    "padding": 24,
    "htmlLabels": true
  }
}}%%
flowchart TD
    classDef action fill:#eef2ff,stroke:#4f46e5,color:#111827,stroke-width:2px,font-size:26px,font-family:Arial;
    classDef decision fill:#f8f7ff,stroke:#4f46e5,color:#111827,stroke-width:2px,font-size:26px,font-family:Arial;
    classDef terminal fill:#ede9fe,stroke:#4f46e5,color:#111827,stroke-width:2px,font-size:24px,font-family:Arial;
    linkStyle default stroke:#374151,stroke-width:2px;

    A([Start]) --> B[Choose Player<br/>Enter name]
    B --> C[Room List<br/>GET rooms + global WebSocket]
    C --> D[Select room<br/>and Join]
    D --> E{Join allowed?}
    E -- No --> C
    E -- Yes --> F[Join success<br/>receive player id]

    F --> G[Lobby<br/>load room + WebSocket]
    G --> H{Host started?}
    H -- No --> G
    H -- Yes --> I[Festival Map<br/>show unlocked booths]

    I --> J[Play unlocked booth]
    J --> K[POST complete]
    K --> L{Submit success?}
    L -- No --> I
    L -- Yes --> M[Save score<br/>unlock next booth]

    M --> N{All booths done?}
    N -- No --> I
    N -- Yes --> O[Wait for host finalize]
    O --> P{Room finished?}
    P -- No --> O
    P -- Yes --> Q[GET summary]
    Q --> R[Summary page]
    R --> S([Exit / timeout])

    class A,S terminal;
    class B,C,D,F,G,I,J,K,M,O,Q,R action;
    class E,H,L,N,P decision;
